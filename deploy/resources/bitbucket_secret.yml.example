# Bitbucket git-sync secret — same pattern as practice-insights-v2
# On ct-sandbox, use the existing platform secret (no apply needed):
#   secret: ct-sandbox:bitbucket-cred-mr
#
# Only apply this if admin creates a dedicated secret for your repo.

name: bitbucket-cred-mr
version: v2alpha
type: secret
tags:
  - git-sync
  - bitbucket
description: Bitbucket credentials for vulcan-sales-workforce repo sync
owner: jitendrakumartmdcio
layer: user

secret:
  type: key-value
  data:
    GITSYNC_USERNAME: <bitbucket-username>
    GITSYNC_PASSWORD: <bitbucket-app-password>

# Referenced in *-deploy.yaml:
#   secret: ct-sandbox:bitbucket-cred-mr
