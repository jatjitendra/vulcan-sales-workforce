# Git sync secret for private repository access
# Apply before vulcan deploy if repo is private:
#   dataos-ctl resource apply -f deploy/resources/git_sync_secret.yml -w ct-sandbox

name: github-token
version: v2alpha
type: secret
tags:
  - sales-workforce
  - git-sync
description: Git credentials for vulcan-sales-workforce repo sync
owner: jitendrakumartmdcio
layer: user

secret:
  type: key-value
  data:
    GITSYNC_USERNAME: jatjitendra
    GITSYNC_PASSWORD: <github-personal-access-token>

# Referenced in sales-workforce-deploy.yaml:
#   secret: ct-sandbox:github-token
