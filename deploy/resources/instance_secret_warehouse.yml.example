# Optional: warehouse credentials for cloud depot (apply before vulcan deploy)
#   cp deploy/resources/instance_secret_warehouse.yml.example deploy/resources/instance_secret_warehouse.yml
#   dataos-ctl apply -f deploy/resources/instance_secret_warehouse.yml -w ct-sandbox

name: sales-workforce-warehouse-secret
version: v1
type: instance-secret
tags:
  - sales-workforce
  - vulcan
description: Warehouse credentials for Sales & Workforce Vulcan project (Pacific / ct-sandbox)
owner: jitendrakumartmdcio
layer: user

instance-secret:
  type: key-value-properties
  acl: rw
  data:
    # Snowflake example
    # SNOWFLAKE_ACCOUNT: YOUR_ACCOUNT
    # SNOWFLAKE_USER: YOUR_USER
    # SNOWFLAKE_PASSWORD: YOUR_PASSWORD
    # SNOWFLAKE_WAREHOUSE: YOUR_WH
    # SNOWFLAKE_DATABASE: YOUR_DB
    # SNOWFLAKE_ROLE: YOUR_ROLE

    # Postgres example
    # POSTGRES_HOST: warehouse
    # POSTGRES_PORT: "5432"
    # POSTGRES_DB: warehouse
    # POSTGRES_USER: vulcan
    # POSTGRES_PASSWORD: vulcan
