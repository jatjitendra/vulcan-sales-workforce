# Local Vulcan + Pacific cloud defaults
# Instance: pacific-051426 | Workspace / tenant: ct-sandbox

# Required on cloud (Vulcan reads this instead of config.yaml tenant key)
DATAOS_TENANT_ID=ct-sandbox
VULCAN_TENANT_ID=ct-sandbox

HEIMDALL_URL=https://pacific-051426.dataos.cloud/heimdall
DATAOS_CONTEXT=pacific-051426
DATAOS_WORKSPACE=ct-sandbox

# Local Postgres stack (docker) — used with config.local.yaml
POSTGRES_HOST=statestore
POSTGRES_PORT=5432
POSTGRES_USER=vulcan
POSTGRES_PASSWORD=vulcan
POSTGRES_DB=statestore

# Git sync secret (if private repo) — create in ct-sandbox workspace first
# GITSYNC_USERNAME=
# GITSYNC_PASSWORD=
